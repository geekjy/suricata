# Default configuration for GitHub Release installs.
# Leave SURICATA_INTERFACE empty to auto-detect the default route device.

SURICATA_INTERFACE=
SURICATA_OPTIONS=

# Optional overrides:
# SURICATA_CONFIG=/opt/suricata/current/etc/suricata.yaml
# SURICATA_LOG_DIR=/opt/suricata/current/var/log
# SURICATA_RUN_DIR=/opt/suricata/current/var/run
# SURICATA_PID_FILE=/opt/suricata/current/var/run/suricata.pid
